<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- 2x2 rounded tile grid, warm dark plates against the near-black backdrop -->
    <path
        android:fillColor="#2B2015"
        android:pathData="M30,28 h20 a6,6 0 0 1 6,6 v20 a6,6 0 0 1 -6,6 h-20 a6,6 0 0 1 -6,-6 v-20 a6,6 0 0 1 6,-6 z" />
    <path
        android:fillColor="#2B2015"
        android:pathData="M58,28 h20 a6,6 0 0 1 6,6 v20 a6,6 0 0 1 -6,6 h-20 a6,6 0 0 1 -6,-6 v-20 a6,6 0 0 1 6,-6 z" />
    <path
        android:fillColor="#2B2015"
        android:pathData="M30,56 h20 a6,6 0 0 1 6,6 v20 a6,6 0 0 1 -6,6 h-20 a6,6 0 0 1 -6,-6 v-20 a6,6 0 0 1 6,-6 z" />
    <path
        android:fillColor="#2B2015"
        android:pathData="M58,56 h20 a6,6 0 0 1 6,6 v20 a6,6 0 0 1 -6,6 h-20 a6,6 0 0 1 -6,-6 v-20 a6,6 0 0 1 6,-6 z" />

    <!-- the single connecting line, brushed gold -->
    <path
        android:strokeWidth="9"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M40,41 L68,41 L68,69">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="40"
                android:startY="41"
                android:endX="68"
                android:endY="69"
                android:startColor="#F8ECC4"
                android:centerColor="#CBA25A"
                android:endColor="#9C7A3D" />
        </aapt:attr>
    </path>

    <!-- endpoint dot, rose-gold radial gradient -->
    <path android:pathData="M68,69 m-9,0 a9,9 0 1 0 18,0 a9,9 0 1 0 -18,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:gradientRadius="9"
                android:centerX="65"
                android:centerY="66"
                android:startColor="#F1CBBB"
                android:centerColor="#C48874"
                android:endColor="#93594A" />
        </aapt:attr>
    </path>
</vector>
